# =============================================================================
# Web Register And Sub2API Import Automation - example environment file
# 复制为 .env 后按需修改。Copy to .env and edit. NEVER commit your real .env.
# =============================================================================

# ---- 本服务 / This service ----
API_KEY=change-this-register-service-key

HOST=127.0.0.1
PORT=5060

# ---- 目标网页 / Target web project (your own / authorized) ----
REGISTER_URL=https://your-public-register-url.example.com

# ---- 浏览器 / Browser ----
HEADLESS=false
BROWSER_TIMEOUT_MS=60000
CODE_TIMEOUT_SECONDS=180

# ---- 浏览器模式 / Browser mode ----
# playwright = 用 Playwright 自带 Chromium（默认，原行为）
# cdp        = 连接你本机手动启动的 Chrome/Edge（连真实浏览器）
BROWSER_MODE=playwright
CDP_ENDPOINT=http://127.0.0.1:9222
# incognito = 每个任务新建无痕 context（不读已有 Cookie，任务结束清空）；推荐
# first     = 复用 browser.contexts[0]（复用已登录 profile，不关闭该 context）
CDP_CONTEXT_POLICY=incognito
# 默认 false：CDP 模式任务结束只关 context，不关你本机 Chrome 进程
CDP_CLOSE_BROWSER=false
#
# 本机 Chrome 需由你手动启动（独立 profile，不读日常浏览器 Cookie）：
# Windows 示例：
# "C:\Program Files\Google\Chrome\Application\chrome.exe" --remote-debugging-port=9222 --user-data-dir="D:\chrome-sub2api-automation-profile" --no-first-run --no-default-browser-check

# ---- 文件与数据库 / Files & database ----
EMAILS_FILE=emails.txt
# 项目A (owned-mail-code-service) 的 accounts.txt 路径，用于自动同步 emails.txt。
# /api/emails/sync 会读它、提取邮箱、写回 emails.txt（只保留还未接入 Sub2API 的邮箱）。
ACCOUNTS_SOURCE_FILE=../owned-mail-code-service/accounts.txt
DB_FILE=data/register_jobs.db

SCREENSHOT_DIR=screenshots
TRACE_DIR=traces

# ---- 项目 A：邮箱验证码服务 / Project A: mail code service ----
MAIL_CODE_SERVICE_BASE=http://127.0.0.1:5050
MAIL_CODE_SERVICE_API_KEY=change-this-mail-service-key
# 邮箱验证码提取规则（透传给项目 A）。默认锁定 ChatGPT/OpenAI 登录码，捕获组 (\d{6}) 即 6 位码。
# 注意：注册码邮件主题含 "ChatGPT"，授权页重新登录码邮件主题含 "OpenAI"（都来自 noreply@tm.openai.com）。
# 主题关键词用逗号 OR 列表，必须同时匹配两类，否则授权重新登录会取不到码（408）。
EMAIL_CODE_PATTERN=(?s)(?:验证码|登录代码|verification code|login code)[^0-9]{0,300}(\d{6})
EMAIL_CODE_SUBJECT_KEYWORD=ChatGPT,OpenAI
EMAIL_CODE_FROM_KEYWORD=openai

# ---- 短信平台总开关 / SMS master switch ----
ENABLE_SMS=true
SMS_PROVIDER=62us
SMS_CODE_PATTERN=\b\d{6}\b
SMS_TIMEOUT_SECONDS=180
SMS_POLL_INTERVAL_SECONDS=5
SMS_AUTO_FINISH_ORDER=true
SMS_AUTO_CANCEL_ON_FAIL=true

# ---- 62-US 配置 / 62-US config ----
US62_BASE=https://api.62-us.com
US62_API_KEY=change-this-us62-key
US62_GOODS_ID=

# ---- 5sim 配置 / 5sim config ----
# country / product 可被 API 请求覆盖；operator 默认按 strategy 自动选成功率最高
FIVESIM_BASE=https://5sim.net
FIVESIM_TOKEN=change-this-5sim-token
# FIVESIM_COUNTRY 留空 = 根据所选服务自动选「接码成功率最高」的国家；
# OAuth 手机验证表单的国家会自动切到与购买国家一致。
FIVESIM_COUNTRY=england
FIVESIM_PRODUCT=openai
FIVESIM_OPERATOR_STRATEGY=manual
FIVESIM_OPERATOR=virtual51
FIVESIM_OPERATOR_FALLBACK=any
FIVESIM_MIN_SUCCESS_RATE=0
FIVESIM_MAX_PRICE=0.07
FIVESIM_MIN_COUNT=1
FIVESIM_EXCLUDE_OPERATORS=

# ---- Sub2API (weishaw/sub2api，JWT 管理员登录) ----
SUB2API_BASE=http://127.0.0.1:8080
SUB2API_ADMIN_EMAIL=admin@example.com
SUB2API_ADMIN_PASSWORD=change-this-sub2api-admin-password
SUB2API_ADMIN_API_KEY=
SUB2API_PLATFORM=openai
SUB2API_ACCOUNT_TYPE=oauth
SUB2API_REDIRECT_URI=http://localhost:1455/auth/callback
# openai 的分组 id（用 GET /api/v1/admin/groups/all 查；如 self 分组）
SUB2API_DEFAULT_GROUP_IDS=1
SUB2API_DEFAULT_CONCURRENCY=10
SUB2API_DEFAULT_PRIORITY=1

# ---- 随机身份 / Random identity ----
MIN_AGE=18
MAX_AGE=45

# ---- 注册阶段选择器 / Registration selectors ----
FREE_REGISTER_SELECTOR=button:has-text("免费注册")
EMAIL_INPUT_SELECTOR=input[placeholder="电子邮件地址"]
EMAIL_CONTINUE_SELECTOR=button:has-text("继续")
EMAIL_CODE_INPUT_SELECTOR=input[name="code"], input[autocomplete="one-time-code"], input:visible
EMAIL_CODE_CONTINUE_SELECTOR=button:has-text("继续")
NAME_INPUT_SELECTOR=input[placeholder="姓名"], input[name="name"]
AGE_INPUT_SELECTOR=input[placeholder="年龄"], input[name="age"]
COMPLETE_BUTTON_SELECTOR=button:has-text("完成账户创建")

# ---- 授权阶段选择器 / Authorization selectors ----
AUTH_CONTINUE_SELECTOR=button:has-text("继续")
PHONE_INPUT_SELECTOR=input[placeholder="电话号码"], input[name="phone"], input[type="tel"]
PHONE_CONTINUE_SELECTOR=button:has-text("继续"), button:has-text("发送验证码")
SMS_CODE_INPUT_SELECTOR=input[placeholder="代码"], input[placeholder="验证码"], input[name="sms_code"], input[autocomplete="one-time-code"]
SMS_CODE_CONTINUE_SELECTOR=button:has-text("继续")

# 当前短信订单（如 5sim openai）不支持 WhatsApp 收码时，遇到 WhatsApp-only 页面的处理：
#   false（默认）= 立即取消订单 + 换号，绝不等 SMS 超时；true = 允许 WhatsApp fallback。
PHONE_ALLOW_WHATSAPP_FALLBACK=false

# ---- 成功判断 / Success detection (optional) ----
SUCCESS_URL_KEYWORD=
SUCCESS_TEXT_KEYWORD=
