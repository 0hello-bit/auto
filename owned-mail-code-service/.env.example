# Copy this file to ".env" and fill in real values. NEVER commit your real .env.

# Strong random secret required to call every /api/* endpoint.
API_KEY=change-this-to-a-strong-secret

# Accounts file loaded on startup (optional). Leave empty to skip auto-loading.
ACCOUNTS_FILE=accounts.txt

# SQLite database file.
DB_FILE=mail_codes.db

# Background polling interval, in seconds.
POLL_INTERVAL_SECONDS=20

# How many most-recent messages to pull per mailbox per poll.
LATEST_MAIL_LIMIT=20

# IMAP server.
IMAP_HOST=outlook.office365.com
IMAP_PORT=993

# Microsoft OAuth2 token endpoint and IMAP scope.
TOKEN_URL=https://login.microsoftonline.com/consumers/oauth2/v2.0/token
IMAP_SCOPE=https://outlook.office.com/IMAP.AccessAsUser.All offline_access

# Bind address. Keep 127.0.0.1 unless behind a secured reverse proxy.
HOST=127.0.0.1
PORT=5050

# Default verification-code regex (used by the poller and as the /api/code default).
DEFAULT_CODE_PATTERN=\b\d{4,8}\b
