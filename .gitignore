# ---- local secrets / private runtime config ----
**/.env
**/.env.*
!**/.env.example

# Outlook mailbox credentials / OAuth refresh tokens
owned-mail-code-service/accounts*.txt*
!owned-mail-code-service/accounts.example.txt

# Local mailbox pool state
web-register-sub2api-automation/emails.txt
/已有邮箱.txt

# ---- runtime data ----
**/*.db*
**/*.sqlite
**/*.sqlite3
**/*.bundle
**/*.log
**/logs/
*.bak
*.bak-*
*.friend-bak
*.tmp
*.old
*.lnk

web-register-sub2api-automation/data/*
!web-register-sub2api-automation/data/.gitkeep
web-register-sub2api-automation/screenshots/*
!web-register-sub2api-automation/screenshots/.gitkeep
web-register-sub2api-automation/traces/*
!web-register-sub2api-automation/traces/.gitkeep

# ---- Python / tooling caches ----
**/.venv/
**/venv/
**/env/
**/__pycache__/
**/*.py[cod]
**/*.egg-info/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
build/
dist/

# ---- editor / OS ----
.claude/
.vscode/
.idea/
.DS_Store
Thumbs.db

# local pasted screenshots / ad-hoc images at repo root
/*.png
/*.jpg
/*.jpeg
